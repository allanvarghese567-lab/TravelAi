{
  "compilerOptions": {
    "module": "commonjs",

    "target": "ES2022",

    "moduleResolution": "node",

    "types": ["node"],

    "strict": true,

    "esModuleInterop": true,

    "emitDecoratorMetadata": true,

    "experimentalDecorators": true,

    "skipLibCheck": true,

    "forceConsistentCasingInFileNames": true,

    "resolveJsonModule": true,

    "baseUrl": ".",

    "paths": {
      "@shared/*": ["packages/shared/src/*"]
    }
  }
}

{
  "name": "travel-ai-platform",
  "version": "1.0.0",
  "private": true,

  "workspaces": [
    "apps/*",
    "packages/*"
  ],

  "scripts": {
    "dev:gateway": "npm --workspace apps/api-gateway run dev",
    "dev:auth": "npm --workspace apps/auth-service run dev",
    "dev:location": "npm --workspace apps/location-service run dev",
    "dev:itinerary": "npm --workspace apps/itinerary-service run dev",
    "dev:recommendation": "npm --workspace apps/recommendation-service run dev",
    "dev:trip": "npm --workspace apps/trip-service run dev",

    "dev:all": "npm-run-all --parallel dev:*"
  },

  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}